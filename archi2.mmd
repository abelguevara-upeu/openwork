---
description: "Diagrama de Arquitectura de Alto Nivel - OpenWork"
config:
  layout: elk
---
graph TD
    %% =========================================
    %% CAPA FRONTEND (MÓVIL / WEB)
    %% =========================================
    subgraph Capa_Frontend [Frontend - Interfaces de Usuario]
        AppEmpleador[App Empleador - React Native / Flutter]
        AppEmpleado[App Empleado - React Native / Flutter]
    end

    %% =========================================
    %% CAPA DE ENTRADA Y SEGURIDAD
    %% =========================================
    subgraph Capa_Gateway [API Gateway & Edge]
        Gateway[API Gateway / Load Balancer]
        BFF[BFF - Backend For Frontend]
    end

    %% =========================================
    %% CAPA BACKEND (MICROSERVICIOS)
    %% =========================================
    subgraph Capa_Motor_Core[Motor Core]
        MsIdentidad[Microservicio de Identidad y Reputación]
        MsTransacciones[Microservicio Core de Transacciones]
    end

    subgraph Capa_Motor_Tiempo_Real[Motor Tiempo Real]
        MsMatching[Microservicio de Matching en Tiempo Real]
        MsGeocercas[Microservicio de Geocercas]
        MsNotificaciones[Microservicio de Notificaciones Push]
    end

    subgraph Motor_Core
        MsIdentidad
        MsTransacciones
        MsNotificaciones
    end

    %% =========================================
    %% CAPA DE MENSAJERÍA
    %% =========================================
    subgraph Capa_Mensajeria [Bus de Eventos]
        Kafka[Apache Kafka - Broker de Eventos]
    end

    %% =========================================
    %% CAPA DE DATOS (SEGREGADA)
    %% =========================================
    subgraph Capa_Datos [Bases de Datos]
        Oracle[(DB Oracle - Core Persistente)]
        Redis[(Redis - GeoCache y Sesiones)]
    end

    %% Relaciones Frontend -> Gateway
    AppEmpleador -->|HTTP/REST| Gateway
    AppEmpleado <-->|WebSockets bidireccional| Gateway
    
    %% Relaciones Gateway -> Backend
    Gateway --> BFF
    BFF --> MsIdentidad
    BFF --> MsMatching
    BFF --> MsTransacciones

    %% Relaciones Backend -> Base de Datos
    MsIdentidad -->|Lectura/Escritura| Oracle
    MsTransacciones -->|Transacciones ACID| Oracle
    MsMatching <-->|Operaciones Sub-milisegundo| Redis
    
    %% Relaciones Backend -> Kafka
    MsMatching -->|Publica: AlertaGenerada| Kafka
    MsTransacciones -->|Publica: PagoAprobado| Kafka
    MsIdentidad -->|Publica: ReputacionActualizada| Kafka
    
    Kafka -->|Consume| MsNotificaciones
    Kafka -->|Consume| MsTransacciones
    Kafka -->|Consume| MsMatching
    
    %% Relaciones a servicios externos
    MsNotificaciones -->|FCM / APNs| AppEmpleado